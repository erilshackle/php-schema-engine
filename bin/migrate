#!/usr/bin/env php
<?php

/**
 * PHP Schema Engine CLI
 *
 * Available commands:
 *
 *   php bin/migrate --init
 *   php bin/migrate --dry-run
 *   php bin/migrate --yes
 *   php bin/migrate --force
 *   php bin/migrate --status
 *   php bin/migrate --rollback
 *   php bin/migrate --fresh --force
 *   php bin/migrate --generate-models
 *   php bin/migrate --sql
 *   php bin/migrate --schema-sql
 *
 * Examples:
 *
 *   php bin/migrate
 *   php bin/migrate --dry-run
 *   php bin/migrate --sql > migration.sql
 *   php bin/migrate --schema-sql > install.sql
 *
 * Documentation:
 * https://github.com/erilshackle/php-schema-engine
 * 
 * @author erilshackle
 * @version 1.0.0
 * @copyright 2026 Erilando TS Carvalho
 * @license MIT
 */

require 'vendor/autoload.php';

use SchemaEngine\Console\MigrateCommand;

$options = getopt('h', [
    'init',
    'yes',
    'status',
    'dry-run',
    'force',
    'fresh',
    'clear-history',
    'rollback',
    'recreate',
    'generate-models',
    'trace',
    'sql',
    'schema-sql',
    'help'
]);

if (isset($options['help'])|| isset($options['h'])) {

    echo <<<TEXT
PHP Schema Engine

Usage:
  php bin/migrate [options]

Options:

  --init               Initialize project files
  --dry-run            Preview pending changes
  --yes                Skip confirmation prompt
  --force              Allow destructive operations
  --status             Show migration history
  --rollback           Rollback latest migration batch
  --fresh              Drop all tables from database
  --clear-history      Clear migration history
  --generate-models    Generate model classes
  --sql                Export migration SQL
  --schema-sql         Export full schema SQL
  --trace              Show stack trace on errors
  --help               Show this help screen

Examples:

  php bin/migrate
  php bin/migrate --dry-run
  php bin/migrate --yes
  php bin/migrate --status

  php bin/migrate --sql
  php bin/migrate --sql > migration.sql

  php bin/migrate --schema-sql
  php bin/migrate --schema-sql > install.sql

  php bin/migrate --fresh --force

Documentation:

  https://github.com/erilshackle/php-schema-engine

TEXT;

    exit(0);
}

$command = new MigrateCommand();

try {

    $code = $command->run($options);

    exit($code);
} catch (Throwable $e) {

    echo "\n";
    echo "[ERROR] {$e->getMessage()}\n";
    echo "File: {$e->getFile()}:{$e->getLine()}\n";

    if (isset($options['trace'])) {

        echo "\nStack trace:\n\n";

        foreach ($e->getTrace() as $index => $trace) {

            $file =
                $trace['file']
                ?? '[internal]';

            $line =
                $trace['line']
                ?? '?';

            $function =
                $trace['function']
                ?? 'unknown';

            echo "#{$index} {$file}:{$line} {$function}()\n";
        }
    }

    echo "\n";

    exit(1);
}
